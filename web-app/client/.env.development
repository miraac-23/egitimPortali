# API çağrıları Vite proxy üzerinden gider; bu yüzden uygulama göreli "/api" kullanır.
# (Aynı origin -> CORS/403 yok.) Bu değeri "/api" dışında bir şey yapmayın.
VITE_API_BASE=/api

# Vite proxy'sinin yönlendireceği backend HOST'u (yol EKLEMEYİN, sadece host:port).
# Portal API 8085'te çalışır (8080 Spring Boot örneklerine ayrılmıştır).
VITE_BACKEND_URL=http://localhost:8085
